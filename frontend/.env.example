# Frontend (Vite) — loaded from `frontend/.env`
# Copy to `.env` in this folder. Values are baked in at `vite build` time.

# Clerk (browser) — Publishable key from Clerk dashboard. Required for /app (sign-in gate).
# If unset, the app runs in legacy guest mode against the API (not recommended for production).
#
# pk_live_* only works on your production domain (e.g. adhitya.me). For local / Electron dev you can:
# - put pk_test_* in VITE_CLERK_PUBLISHABLE_KEY_DEV (kept alongside pk_live below), or
# - use only pk_test in VITE_CLERK_PUBLISHABLE_KEY while developing, or
# - load the packaged app from your deployed HTTPS URL (INTERVIEWGURU_WEB_APP_URL).
#
# During `vite` dev, if VITE_CLERK_PUBLISHABLE_KEY_DEV is set, it wins over VITE_CLERK_PUBLISHABLE_KEY.
# `vite build` / production bundles ignore *_DEV and use only VITE_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=
# If set, localhost/Electron use this pk_test_* — the API needs matching sk_test_* (see CLERK_SECRET_KEY_DEV in backend/.env.example).
VITE_CLERK_PUBLISHABLE_KEY_DEV=

# Used client-side for TTS (see useAIAssistant)
GEMINI_API_KEY=

# Optional: full API base URL if the UI is not served from the same origin as `/api`
# Example: https://your-api.vercel.app  (no trailing slash)
# Leave empty for same-origin `/api` (local Express or single Vercel project)
VITE_API_URL=

# BYOK: production builds send the user's Groq key (settings → localStorage) as x-api-key. Requires BYOK_MODE=true on the API.
# VITE_BYOK=true
