# Backend (Express) — loaded from `backend/.env`
# Copy to `.env` in this folder and fill in real values.

# Groq: for BYOK launch set BYOK_MODE=true and leave this empty (users send x-api-key from the app).
# Optional fallback if you also want server-side Groq for users without a key.
GROQ_API_KEY=

# BYOK (bring your own key): in production, honor user x-api-key from the browser. Pair with VITE_BYOK=true on the frontend build.
# BYOK_MODE=true

# Alternative to BYOK_MODE: allow client keys without the BYOK name (same behavior)
# ALLOW_CLIENT_GROQ_KEY=true

# Max JSON body size for Express (default 25mb). Raise only if needed for large audio base64 payloads.
# JSON_BODY_LIMIT=25mb

# Clerk (server) — required in production to identify users and enforce quotas
# Get from https://dashboard.clerk.com → API Keys → Secret key
CLERK_SECRET_KEY=

# Same publishable key as the frontend (`pk_live_...` / `pk_test_...`). Required by @clerk/express at runtime.
# On Vercel, set this for Production (or rely on VITE_CLERK_PUBLISHABLE_KEY — the server reads either).
CLERK_PUBLISHABLE_KEY=

# PostgreSQL — recommended: Neon pooler URL (see backend/config/database.config.ts).
# Supabase pooler :6543 also works. One DATABASE_URL only.
# After setting this, run from repo root: npm run db:migrate
DATABASE_URL=

# Optional: set to "false" only for local Postgres without TLS
# DATABASE_SSL=false

# Optional: cap new signups per IP per 24h (0 = disabled). Helps reduce throwaway free accounts.
# ABUSE_MAX_SIGNUPS_PER_IP_PER_DAY=3

# Optional: max API requests per minute per user or IP (default 180)
# API_RATE_LIMIT_PER_MINUTE=120

# Optional: HTTP port when running `npm run dev` / `npm start` (default 3000)
PORT=3000

# Comma-separated browser origins allowed for credentialed CORS (scheme + host + port, no trailing slash).
# Required for custom domains in production (e.g. https://yourdomain.com). Local dev also allows localhost:5173/3000.
# Vercel adds https://$VERCEL_URL automatically.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
